YOUTUBE_BASE_URL=https://www.googleapis.com/youtube/v3
YOUTUBE_API_KEY=replace-with-your-real-api-key
YOUTUBE_TIMEOUT_SECONDS=60
YOUTUBE_MAX_RETRIES=4
YOUTUBE_RETRY_BACKOFF_SECONDS=1.5
YOUTUBE_RETRY_BACKOFF_MULTIPLIER=2.0
YOUTUBE_MIN_REQUEST_INTERVAL_SECONDS=0.6
YOUTUBE_SEARCH_PAGE_SIZE=25
YOUTUBE_MAX_SEARCH_PAGES_PER_RUN=10
YOUTUBE_MAX_SEARCH_RESULTS_PER_RUN=250
YOUTUBE_MAX_VIDEO_DETAILS_PER_RUN=250
YOUTUBE_MAX_RETRY_AFTER_SECONDS=120
YOUTUBE_USER_AGENT=youtube-video-search/1.0
