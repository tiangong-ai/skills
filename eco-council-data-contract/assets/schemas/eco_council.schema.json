          "$ref": "#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "statement": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "meaning": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "needs_physical_validation": {
          "type": "boolean"
        },
        "worth_storing": {
          "type": "boolean"
        },
        "source_signal_count": {
          "type": "integer",
          "minimum": 0
        },
        "time_window": {
          "$ref": "#/$defs/timeWindow"
        },
        "place_scope": {
          "$ref": "#/$defs/regionScope"
        },
        "public_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        },
        "compact_audit": {
          "$ref": "#/$defs/compactAudit"
        }
      },
      "required": [
        "schema_version",
        "submission_id",
        "run_id",
        "round_id",
        "agent_role",
        "claim_id",
        "claim_type",
        "summary",
        "statement",
        "meaning",
        "priority",
        "needs_physical_validation",
        "worth_storing",
        "time_window",
        "place_scope",
        "public_refs"
      ]
    },
    "observationSubmission": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "submission_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "run_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "round_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
