          "enum": [
            "point",
            "window-summary",
            "series-summary",
            "event-count"
          ]
        },
        "value": {
          "type": [
            "number",
            "null"
          ]
        },
        "unit": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "meaning": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "worth_storing": {
          "type": "boolean"
        },
        "time_window": {
          "$ref": "#/$defs/timeWindow"
        },
        "place_scope": {
          "$ref": "#/$defs/regionScope"
        },
        "quality_flags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "provenance": {
          "$ref": "#/$defs/artifactRef"
        },
        "compact_audit": {
          "$ref": "#/$defs/compactAudit"
        }
      },
      "required": [
        "schema_version",
        "submission_id",
        "run_id",
        "round_id",
        "agent_role",
        "observation_id",
        "source_skill",
        "metric",
        "aggregation",
        "unit",
        "meaning",
        "worth_storing",
        "time_window",
        "place_scope",
        "quality_flags",
        "provenance"
      ]
    },
    "dataReadinessReport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
