            "contradicts",
            "mixed",
            "insufficient"
          ]
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "public_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        },
        "observation_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "required": [
        "schema_version",
        "evidence_id",
        "run_id",
        "round_id",
        "claim_id",
        "verdict",
        "confidence",
        "summary",
        "public_refs",
        "observation_ids",
        "gaps"
      ]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "finding_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "claim_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "observation_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "required": [
        "finding_id",
        "title",
        "summary",
        "confidence"
      ]
    },
    "claimSubmission": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "submission_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "run_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "round_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "agent_role": {
          "enum": [
            "moderator",
            "sociologist",
            "environmentalist",
            "historian"
          ]
        },
        "claim_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
